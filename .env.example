# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here           # optional — only if using Gemini

# ── Per-agent model config (each agent can have its own model) ─────────────────
# Valid Claude models:
#   claude-opus-4-6          most capable, ~5x cost of Sonnet
#   claude-sonnet-4-6        best balance, recommended default
#   claude-haiku-4-5-20251001  fastest/cheapest
# Valid Gemini models:
#   gemini-2.0-flash-lite    free tier
#   gemini-2.0-flash
#
ANALYST_MODEL=claude-opus-4-6        # deep reasoning once/day — worth the cost
SCOUT_MODEL=claude-sonnet-4-6        # good balance
COMMIT_MODEL=claude-sonnet-4-6       # good balance
SETTLER_MODEL=claude-sonnet-4-6      # settler barely uses LLM

# Global fallback (used if per-agent var is not set)
LLM_PROVIDER=claude                  # claude | gemini
CLAUDE_MODEL=claude-sonnet-4-6
GEMINI_MODEL=gemini-2.0-flash-lite

# ── GitHub (data store + dashboard host) ──────────────────────────────────────
# Create a fine-grained PAT with Contents: read+write on your repo
GH_PAT=your_github_fine_grained_token_here
GITHUB_REPO=your_username/tobias     # e.g. joaopgms/tobias

# ── Odds ──────────────────────────────────────────────────────────────────────
ODDSPAPI_KEY=your_oddspapi_key_here  # free tier at oddspapi.io — no credit card

# ── Security notes ────────────────────────────────────────────────────────────
# This file is a TEMPLATE. Never commit a .env file with real values.
# In GitHub Actions, all vars above are set as Repository Secrets/Variables.
# .env is in .gitignore and will never be committed.
